# Copy to .env for local runs (do not commit .env). Railway uses its own Variables UI.
PORT=3000
# Where the JSON store lives. On Railway, mount a Volume (e.g. at /data) and set:
#   DATA_FILE=/data/store.json
DATA_FILE=./data/store.json
# Leave blank to run open (local testing only). SET a strong value before real use —
# it gates reading submissions and editing config/maps.
ADMIN_CODE=
